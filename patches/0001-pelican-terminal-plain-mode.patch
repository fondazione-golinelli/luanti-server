+static bool env_var_true(const char *value)
+{
+	if (!value || !*value)
+		return false;
+
+	return std::strcmp(value, "0") != 0 &&
+		std::strcmp(value, "false") != 0 &&
+		std::strcmp(value, "FALSE") != 0;
+}
+
+static bool use_plain_terminal_mode()
+{
+	// Container control panels tend to emulate a PTY that does not play well
+	// with ncurses redraw semantics. Allow explicit opt-in and auto-enable for
+	// TERM=dumb style environments.
+	if (env_var_true(std::getenv("LUANTI_TERMINAL_PLAIN")))
+		return true;
+
+	const char *term = std::getenv("TERM");
+	if (!term)
+		return false;
+
+	return std::strcmp(term, "dumb") == 0 || std::strcmp(term, "unknown") == 0;
+}
+
+static std::string luanti_markup_to_ansi(std::wstring_view input)
+{
+	// Resolve translation escapes and convert Luanti color escapes
+	// (\x1b(c@...), \x1b(b@...)) to ANSI colors so panel consoles render
+	// colored output instead of raw Luanti escape fragments.
+	std::wstring text = translate_string(input);
+	std::wstring plain_buf;
+	std::string output;
+
+	video::SColor fg;
+	video::SColor bg;
+	bool has_fg = false;
+	bool has_bg = false;
+	bool has_ansi = false;
+
+	auto flush_plain = [&]() {
+		if (plain_buf.empty())
+			return;
+		output.append(wide_to_utf8(plain_buf));
+		plain_buf.clear();
+	};
+
+	auto append_ansi = [&]() {
+		if (!has_fg && !has_bg)
+			return;
+
+		output.append("\x1b[");
+		bool needs_sep = false;
+		if (has_fg) {
+			output.append("38;2;");
+			output.append(std::to_string(fg.getRed()));
+			output.push_back(';');
+			output.append(std::to_string(fg.getGreen()));
+			output.push_back(';');
+			output.append(std::to_string(fg.getBlue()));
+			needs_sep = true;
+		}
+		if (has_bg) {
+			if (needs_sep)
+				output.push_back(';');
+			output.append("48;2;");
+			output.append(std::to_string(bg.getRed()));
+			output.push_back(';');
+			output.append(std::to_string(bg.getGreen()));
+			output.push_back(';');
+			output.append(std::to_string(bg.getBlue()));
+		}
+		output.push_back('m');
+		has_ansi = true;
+	};
+
+	for (size_t i = 0; i < text.length();) {
+		if (text[i] != L'\x1b') {
+			plain_buf.push_back(text[i]);
+			++i;
+			continue;
+		}
+
+		++i;
+		if (i >= text.length())
+			break;
+
+		size_t start_index = i;
+		size_t length = 1;
+		if (text[i] == L'(') {
+			++i;
+			++start_index;
+			while (i < text.length() && text[i] != L')') {
+				if (text[i] == L'\\')
+					++i;
+				++i;
+			}
+			length = i - start_index;
+			if (i < text.length())
+				++i;
+		} else {
+			++i;
+		}
+
+		std::wstring esc(text, start_index, length);
+		auto parts = split(esc, L'@');
+		if (parts.empty())
+			continue;
+
+		if (parts[0] == L"c" && parts.size() > 1) {
+			video::SColor color;
+			if (parseColorString(wide_to_utf8(parts[1]), color, true, 255)) {
+				flush_plain();
+				fg = color;
+				has_fg = true;
+				append_ansi();
+			}
+		} else if (parts[0] == L"b" && parts.size() > 1) {
+			video::SColor color;
+			if (parseColorString(wide_to_utf8(parts[1]), color, true, 255)) {
+				flush_plain();
+				bg = color;
+				has_bg = true;
+				append_ansi();
+			}
+		}
+		// Translation escapes and unknown escapes are intentionally ignored.
+	}
+
+	flush_plain();
+	if (has_ansi)
+		output.append("\x1b[0m");
+	return output;
+}
